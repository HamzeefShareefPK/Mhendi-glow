# MehndiDesignPics — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Google Analytics 4 ───────────────────────────────
# Get from: analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Google AdSense ───────────────────────────────────
# Get from: adsense.google.com
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# ── Cloudinary (for image hosting) ──────────────────
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Site URL ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mehndidesignpics.com

# ── Unsplash (distinct per-category images) ──────────
# Free Access Key from https://unsplash.com/developers
# After setting, run: npm run fetch-unsplash  (then rebuild & commit
# src/data/unsplashPhotos.json) to give each category its own real photos.
UNSPLASH_ACCESS_KEY=

# ── Contact Email ─────────────────────────────────────
CONTACT_EMAIL=hello@mehndidesignpics.com

# ── Google Search Console verification ───────────────
# GSC → Settings → Ownership verification → HTML tag (content value only)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── IndexNow (Bing/Yandex instant indexing) ──────────
# Must match the filename/content of public/<key>.txt
INDEXNOW_KEY=8f3a9c2e7b1d4f6a0c5e8b2d7a4f1c9e
# Secret protecting the POST /api/indexnow admin route
INDEXNOW_ADMIN_SECRET=
